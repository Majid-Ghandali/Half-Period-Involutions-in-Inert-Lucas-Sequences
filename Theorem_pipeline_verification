from sage.all import GF, PolynomialRing, Matrix, vector, legendre_symbol, primes
import csv
import json

============================================================================

Configuration

============================================================================

VERIFY_CHARACTER_SUMS = True
EXPORT_JSON = True
SCAN_BOUND = 200

PROOF_MAP = {
"Step1": "Inertness of discriminant over F_p",
"Step2": "Irreducible quadratic and explicit construction of F_{p^2}",
"Step3": "Norm identity N(lambda)=Q and derived norm-fibre specialization",
"Step4": "Unique involution in the cyclic subgroup <lambda>",
"Step5": "Transfer to the companion matrix A",
"Step6": "Anti-periodicity on state vectors and sequence projections",
"Step7": "Quadratic character-sum cancellation"
}

============================================================================

Utilities

============================================================================

def canonical_mod_int(a, p):
return int(a) % p

def quadratic_character_mod_p(a, p):
"""
Extended quadratic character modulo p:
chi(0) = 0,
chi(a) = (a/p) for a != 0.
"""
a_mod = canonical_mod_int(a, p)
if a_mod == 0:
return 0
return legendre_symbol(a_mod, p)

def lucas_sequences_mod_p(P, Q, p, N):
Fp = GF(p)
Pp, Qp = Fp(P), Fp(Q)

U = [Fp(0), Fp(1)]  
V = [Fp(2), Pp]  

for n in range(2, N + 1):  
    U.append(Pp * U[n - 1] - Qp * U[n - 2])  
    V.append(Pp * V[n - 1] - Qp * V[n - 2])  

return U, V

def state_vectors_from_sequences(U, V, p):
Fp = GF(p)
X = [vector(Fp, [U[n + 1], U[n]]) for n in range(len(U) - 1)]
Y = [vector(Fp, [V[n + 1], V[n]]) for n in range(len(V) - 1)]
return X, Y

def stringify_value(v):
if isinstance(v, (int, str, bool)):
return v
return str(v)

