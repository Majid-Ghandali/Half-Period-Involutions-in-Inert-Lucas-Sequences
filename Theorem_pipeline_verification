def print_case_summary(res):
status = "✓" if res["pipeline_success"] else "✗"
T_str = str(res["T"]) if res["T"] != "" else "NA"

print(  
    f"  {status} {res['Sequence']:15} (p={res['p']:>3}) | "  
    f"T={T_str:>3} | "  
    f"alg={str(res['algebraic_success']):5} | "  
    f"struct={str(res['structural_success']):5} | "  
    f"mat={str(res['matrix_success']):5} | "  
    f"dyn={str(res['dynamical_success']):5} | "  
    f"Status={res['Status']}"  
)

def export_csv(rows, filename):
if not rows:
return
flat_rows = [{k: stringify_value(v) for k, v in row.items()} for row in rows]
headers = list(flat_rows[0].keys())
with open(filename, "w", newline="", encoding="utf-8") as f:
writer = csv.DictWriter(f, fieldnames=headers)
writer.writeheader()
writer.writerows(flat_rows)

def export_json(rows, filename):
payload = {
"metadata": {
"artifact": "Theorem pipeline verification",
"proof_map": PROOF_MAP,
"verify_character_sums": VERIFY_CHARACTER_SUMS,
"scan_bound": SCAN_BOUND
},
"results": [{k: stringify_value(v) for k, v in row.items()} for row in rows]
}
with open(filename, "w", encoding="utf-8") as f:
json.dump(payload, f, ensure_ascii=False, indent=2)

